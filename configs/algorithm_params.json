{
  "task": "object_detection",
  "model_family": "YOLOv8-s",
  "num_classes": 1,
  "classes": ["solar-panel"],
  "input_size": [640, 640],
  "model_test_cfg": {
    "multi_label": true,
    "nms_pre": 30000,
    "score_thr": 0.001,
    "nms": {
      "type": "nms",
      "iou_threshold": 0.7
    },
    "max_per_img": 300
  },
  "unchanged_model_params": {
    "deepen_factor": 0.33,
    "widen_factor": 0.5,
    "strides": [8, 16, 32],
    "last_stage_out_channels": 1024,
    "num_det_layers": 3,
    "norm_cfg": {
      "type": "BN",
      "momentum": 0.03,
      "eps": 0.001
    }
  }
}
